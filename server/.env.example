# Copy to .env and fill in. NEVER commit the real .env.

# Razorpay (Dashboard > Settings > API Keys). Use TEST keys for development.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# Razorpay Dashboard > Settings > Webhooks > the secret you set when creating the webhook.
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Admin panel: single shared password (no usernames).
ADMIN_PASSWORD=change-me-strong-password
# Secret used to sign admin session tokens. Use a long random string.
JWT_SECRET=replace-with-a-long-random-string

# Server
PORT=8787
# Comma-separated list of allowed frontend origins for CORS.
CORS_ORIGIN=http://localhost:5501
# SQLite file path (defaults to ./sajigaz.db). On Render, point this at a mounted disk.
DB_PATH=./sajigaz.db
